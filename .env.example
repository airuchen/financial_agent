# LLM Provider: "ollama" or "openai"
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:7b
LLM_TEMPERATURE=0

# Ollama (only if LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI (only if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-key-here

# Tavily
TAVILY_API_KEY=tvly-your-key-here

# API
API_HOST=0.0.0.0
API_PORT=8000
LLM_TIMEOUT=30
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=false
AUTH_ENABLED=false
# Comma-separated `id:sha256hex` entries, e.g. `researcher1:abc123...`
API_KEY_HASHES=local:replace_with_sha256_hex
RATE_LIMIT_MINUTE=60
RATE_LIMIT_HOUR=600

# Cache
CACHE_ENABLED=true
REDIS_URL=redis://localhost:6379/0
CACHE_PROMPT_REVISION=v1
CACHE_TTL_DIRECT_SEC=86400
CACHE_TTL_SEARCH_RESULTS_SEC=900
CACHE_TTL_SEARCH_ANSWER_SEC=300
